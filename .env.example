# Required: where SQLite db lives
DATABASE_URL=file:./data/db.sqlite

# Required: 32+ char random string for session signing
# Generate: openssl rand -base64 32
SESSION_SECRET=changeme-32-bytes-random-base64

# Optional: leave empty to auto-generate + persist in /app/data/.rcon_key
# To pin: openssl rand -base64 32
RCON_KEY=

# Docker daemon endpoint (use socket-proxy in production)
DOCKER_HOST=tcp://socket-proxy:2375

# Optional: when sidecars need to reach the host (default: host.docker.internal)
MAP_PROXY_UPSTREAM_HOST=host.docker.internal

# Public origin used in cookies and links (your panel URL)
ORIGIN=https://panel.example.com

# Trust proxy headers from reverse proxy (nginx/Caddy/etc)
PROTOCOL_HEADER=x-forwarded-proto

# Production
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TZ=UTC

# Settings below can also be configured via UI Settings page (preferred)

# Drasl self-hosted auth server
DRASL_BASE_URL=https://mc.example.com
DRASL_ADMIN_TOKEN=

# Discord webhook for global notifications
DISCORD_WEBHOOK_URL=
